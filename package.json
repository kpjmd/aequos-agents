{
  "name": "aequos-agents",
  "version": "1.0.0",
  "description": "AI-powered agent framework for orthopedic medical applications",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "seed:equipoise": "node scripts/seed-equipoise.js",
    "seed:anchor-overlay": "node scripts/seed-anchor-overlay.js",
    "benchmark:probe": "node scripts/benchmark-probe.js",
    "screen:vignette": "node scripts/screen-vignette.js",
    "anchor-set:migrate": "node anchor-set/scripts/migrate-from-csv.mjs",
    "anchor-set:validate": "node anchor-set/scripts/validate.mjs",
    "anchor-set:manifest": "node anchor-set/scripts/build-manifest.mjs",
    "detector:run": "node detector/index.js",
    "recalibrate": "node recalibration/index.js",
    "validation:run": "node validation/run.js",
    "grounding:run": "node grounding/index.js",
    "lint": "eslint src/ tests/ examples/ detector/ recalibration/ validation/ anchor-set/ grounding/",
    "example": "node examples/basic-agent.js",
    "compile:contract": "hardhat compile",
    "deploy:contract": "hardhat run scripts/deploy.cjs --network base-sepolia",
    "authorize:agents": "hardhat run scripts/authorize-agents.cjs --network base-sepolia",
    "check:balances": "hardhat run scripts/check-balances.cjs --network base-sepolia",
    "verify:contract": "hardhat verify --network base-sepolia"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.29.0",
    "@coinbase/agentkit": "^0.10.2",
    "@coinbase/agentkit-langchain": "^0.3.0",
    "@coinbase/cdp-agentkit-core": "^0.0.14",
    "@coinbase/cdp-langchain": "^0.0.15",
    "@coinbase/cdp-sdk": "^1.38.1",
    "@farcaster/quick-auth": "^0.0.8",
    "@langchain/anthropic": "^0.3.34",
    "@langchain/core": "^0.3.21",
    "@langchain/langgraph": "^0.2.16",
    "@neondatabase/serverless": "^1.0.2",
    "bull": "^4.16.5",
    "csv-parse": "^7.0.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "express": "^4.21.1",
    "express-rate-limit": "^8.5.1",
    "express-sse": "^1.0.0",
    "fast-xml-parser": "^4.3.0",
    "helmet": "^8.1.0",
    "lru-cache": "^11.2.2",
    "node-fetch": "^3.3.2",
    "p-queue": "^8.1.1",
    "p-timeout": "^7.0.0",
    "uuid": "^11.0.3",
    "winston": "^3.15.0",
    "ws": "^8.18.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@types/node": "^22.10.1",
    "eslint": "^9.15.0",
    "globals": "^17.6.0",
    "hardhat": "^2.22.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "ai",
    "agents",
    "orthopedic",
    "medical",
    "blockchain",
    "langchain"
  ],
  "author": "AequOs Team",
  "license": "MIT"
}
